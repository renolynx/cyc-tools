{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/community-write.js": { "maxDuration": 60 },
    "api/photo-upload.js":    { "maxDuration": 60 },
    "api/health.js":          { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/health", "schedule": "0 * * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/weekly-calendar", "destination": "/" },
    { "source": "/tools", "destination": "/tools/index.html" },
    { "source": "/event-card", "destination": "/event-card/index.html" },
    { "source": "/team", "destination": "/team/index.html" },
    { "source": "/me/timeline", "destination": "/me/timeline/index.html" },
    { "source": "/food", "destination": "/food/index.html" },
    { "source": "/youyang", "destination": "/youyang/index.html" },
    { "source": "/events/:id", "destination": "/api/event-page?id=:id" },
    { "source": "/events", "destination": "/api/events-list" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap-xml" },
    { "source": "/community/admin", "destination": "/api/community-page?mode=admin" },
    { "source": "/community/memories", "destination": "/community/memories/index.html" },
    { "source": "/community/:id", "destination": "/api/community-page?id=:id" },
    { "source": "/community", "destination": "/api/community-page" }
  ]
}
